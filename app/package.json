    "@types/jest": "^29.5.14",
    "@types/node": "^22.19.15",
    "@types/pino": "^7.0.4",
    "concurrently": "^9.1.2",
    "esbuild": "^0.25.2",
    "jest": "^29.7.0",
    "nodemon": "^3.1.9",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.1017.0",
    "@aws-sdk/lib-dynamodb": "^3.1017.0",
