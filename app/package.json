{
  "name": "core-lambda-product",
  "version": "1.0.0",
  "description": "",
  "main": "dist/index.js",
  "scripts": {
    "test": "export NODE_ENV=local && jest",
    "tdd": "export NODE_ENV=local && jest --watch",
    "coverage": "export NODE_ENV=local && npm test -- --coverage",
    "watch-ts": "esbuild index.ts --bundle --platform=node --target=node20 --outfile=dist/index.js --watch",
    "start": "export NODE_ENV=local && nodemon ./__tests__/utils/localRunner.ts",
    "dev": "concurrently \"npm run watch-ts\" \"npm run start\"",
    "build": "node esbuild.config.js",
    "start-ts": "nodemon --exec ts-node ./index.ts",
    "start:prod": "node dist/index.js"
  },
  "keywords": [],
