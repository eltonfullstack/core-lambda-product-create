{
  "name": "lambda-product-create",
  "version": "1.0.0",
  "main": "dist/index.js",
  "type": "commonjs",
  "scripts": {
    "test": "cross-env NODE_ENV=local jest",
    "tdd": "cross-env NODE_ENV=local jest --watch",
    "coverage": "cross-env NODE_ENV=local jest --coverage",
    "lint": "eslint \"src/**/*.ts\"",
    "lint:fix": "eslint src --ext .ts --fix",
    "dev": "cross-env NODE_ENV=local nodemon --exec ts-node -r tsconfig-paths/register ./__tests__/utils/localRunner.ts",
    "build": "esbuild src/modules/product/infra/lambda/createProduct.ts --bundle --platform=node --target=node20 --outfile=dist/createProduct.js",
    "start": "node dist/createProduct.js",
    "sast": "pnpm audit --audit-level=moderate"
  },
  "packageManager": "pnpm@9.0.0",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/aws-lambda": "^8.10.161",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.15.29",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "cross-env": "^7.0.3",
    "esbuild": "^0.25.2",
    "eslint": "^10.2.1",
    "eslint-plugin-jest": "^29.15.2",
    "jest": "^29.7.0",
    "nodemon": "^3.1.9",
    "pino-pretty": "^13.1.3",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.58.2"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.1024.0",
    "@aws-sdk/lib-dynamodb": "^3.1024.0",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "pino": "^9.6.0",
    "uuid": "^13.0.0",
    "zod": "^4.3.6"
  }
}