{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "ignoreDeprecations": "6.0",
    "strict": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "outDir": "dist",
    "baseUrl": "./src",
    "rootDir": "src",
    "types": ["jest", "node"],
    "paths": {
      "@modules/*": ["modules/*"],
      "@shared/*": ["shared/*"]
    },
    "typeRoots": ["./types", "./node_modules/@types"]
  },
  "include": [
    "src/**/*",
    "types/**/*"
  ]
}