
{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "ignoreDeprecations": "6.0",
    "strict": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "outDir": "dist",
    "baseUrl": "./src",
    "rootDir": ".",
    "types": ["jest", "node"],

    "paths": {
      "@controller/*": ["controller/*"],
      "@service/*": ["service/*"],
      "@repository/*": ["repository/*"],
      "@dto/*": ["dto/*"],
      "@interfaces/*": ["interfaces/*"],
      "@utils/*": ["utils/*"]
    },

    "typeRoots": ["./types", "./node_modules/@types"]
  },
  "include": ["src", "types", "__tests__", "src/**/*", "types/**/*", "__tests__/**/*"]
}
